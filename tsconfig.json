{
  "compilerOptions": {
    "target": "ES2021",              // 최신 JavaScript 기능 지원
    "module": "ESNext",              // ECMAScript Modules 사용
    "moduleResolution": "Node",     // 모듈 해석 방식
    "strict": true,                 // 엄격한 타입 검사
    "esModuleInterop": true,        // CommonJS와 호환
    "outDir": "./dist",             // 컴파일 결과 출력 폴더
    "rootDir": "./src" ,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,     
    "strictPropertyInitialization":false        // 소스 폴더
  },
  "ts-node": {
    "esm": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
